OPENAI_API_KEY=sk-your-openai-api-key-here

# 本地 ASR 服务（如 Qwen3-ASR-1.7B via vllm）
# 设置后将替代 OpenAI Whisper 进行语音转录，OPENAI_API_KEY 仍用于 AI 纪要
# ASR_BASE_URL=http://localhost:8000
# ASR_MODEL=Qwen/Qwen3-ASR-1.7Bß
# ASR_API_KEY=EMPTY
PORT=3001
JWT_SECRET=replace-with-a-long-random-secret
APP_BASE_URL=http://localhost:3000
TURN_URLS=turn:turn.example.com:3478?transport=udp,turns:turn.example.com:5349?transport=tcp
TURN_USERNAME=turn-user
TURN_CREDENTIAL=turn-password
TURN_REALM=aimeeting.local
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_PASS=replace-with-mail-password
SMTP_FROM=AiMeeting <noreply@example.com>

