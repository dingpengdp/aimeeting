OPENAI_API_KEY=sk-your-openai-api-key-here

# 系统管理员（可选）
# 设置后该邮箱登录的用户拥有管理员权限
# 管理员可在首页及会议中通过 UI 配置 ASR / LLM 服务，无需修改此文件
# ADMIN_EMAIL=admin@example.com

# HuggingFace Token（用于下载需要登录的模型，如 whisper-large-v3）
# 从 https://huggingface.co/settings/tokens 免费申请（Read 权限即可）
# 也可在管理员 Web UI → AI 配置面板中填写，保存后重启 ASR 服务生效
# HF_TOKEN=hf_xxxxxxxxxxxxxxxx

# 本地 ASR 服务（如 Qwen3-ASR-1.7B via vllm）
# 设置后将替代 OpenAI Whisper 进行语音转录，OPENAI_API_KEY 仍用于 AI 纪要
# ASR_BASE_URL=http://localhost:8000
# ASR_MODEL=Qwen/Qwen3-ASR-1.7B
# ASR_API_KEY=EMPTY

# 自定义 LLM 服务（用于 AI 会议纪要生成）
# 设置后将替代 OpenAI GPT-4o；兼容任意 OpenAI Chat Completions API 的本地或云端模型
# LLM_BASE_URL=http://localhost:11434   # 示例：Ollama
# LLM_MODEL=qwen3                       # 模型名，与服务端一致
# LLM_API_KEY=EMPTY                     # 本地服务通常不需要真实 key
PORT=3001
JWT_SECRET=replace-with-a-long-random-secret
APP_BASE_URL=http://localhost:3000
TURN_URLS=turn:turn.example.com:3478?transport=udp,turns:turn.example.com:5349?transport=tcp
TURN_USERNAME=turn-user
TURN_CREDENTIAL=turn-password
TURN_REALM=aimeeting.local
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_PASS=replace-with-mail-password
SMTP_FROM=AiMeeting <noreply@example.com>

